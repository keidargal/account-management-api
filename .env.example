# Copy this file to `.env` and adjust values for your machine.
# Never commit `.env` (secrets / local overrides).

# Used by docker-compose.yml for the Postgres container (must match DATABASE_URL below).
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=account_management
DB_PORT=5432

# Prisma and the Nest app read this. Host/port/database must match how you run Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/account_management?schema=public"

# Optional. HTTP port for the API (default 3000 if unset).
# PORT=3000
